{
	"$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
	"linter": {
		"rules": {
			"recommended": true,
			"nursery": {
				"useSortedClasses": "error"
			},
			"complexity": {
				"noForEach": "info"
			}
		}
	},
	"files": {
		"include": ["**/*.ts", "**/*.tsx"]
	},
	"formatter": {
		"lineWidth": 120
	},
	"organizeImports": {
		"enabled": true
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "asNeeded",
			"attributePosition": "auto"
		}
	}
}
